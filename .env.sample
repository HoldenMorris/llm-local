# Third-party reputation API keys for url-analyze.sh -t
# Copy to .env (gitignored) and fill in. url-analyze.sh sources .env automatically.

# VirusTotal (required for the VT lookup). Free key: https://www.virustotal.com/gui/my-apikey
# Docs: https://docs.virustotal.com/reference/overview
VT_API_KEY=

# urlscan.io (OPTIONAL -- public search works keyless, a key raises rate limits).
# Key: https://urlscan.io/user/profile/
URLSCAN_API_KEY=

# Anthropic / Claude (for -m claude-<id> verdict LLM and VISION_MODEL=claude-<id> screenshot reader).
# Opt-in only -- sends page text / screenshots to the API. Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
